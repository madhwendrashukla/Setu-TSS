generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HeroSlide {
  id            String   @id @default(uuid()) @db.Uuid
  image_url     String
  display_order Int
  is_active     Boolean  @default(true)

  @@map("hero_slides")
}

model HomepageContent {
  id                    String   @id @default(uuid()) @db.Uuid
  hero_heading          String
  hero_tagline          String
  hero_scene1_heading   String?
  hero_scene1_tagline   String?
  hero_scene2_heading   String?
  hero_scene2_tagline   String?
  hero_rotation_seconds Int      @default(5)
  updated_at            DateTime @updatedAt

  @@map("homepage_content")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  slug        String   @unique
  description String
  banner_url       String?
  venue            String?
  city             String?
  start_date       DateTime? @db.Date
  end_date         DateTime? @db.Date
  registration_url String?
  is_past     Boolean  @default(false)
  is_pinned   Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("tss_events")
}

model Mentor {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  title         String
  bio           String?
  photo_url     String?
  linkedin_url  String?
  display_order Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@map("mentors")
}

model Program {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  subtitle        String?
  description     String?
  duration        String?
  price           String?
  cta_text        String?
  lead_source_tag String?
  display_order   Int
  is_active       Boolean  @default(true)

  @@map("programs")
}

model GalleryItem {
  id            String   @id @default(uuid()) @db.Uuid
  type          String
  media_url     String
  caption       String?
  display_order Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@map("gallery_items")
}

model Testimonial {
  id                String   @id @default(uuid()) @db.Uuid
  type              String
  name              String?
  city              String?
  photo_url         String?
  quote             String?
  youtube_url       String?
  video_heading     String?
  video_description String?
  show_description  Boolean  @default(true)
  event_tag         String?
  display_order     Int
  is_active         Boolean  @default(true)

  @@map("testimonials")
}

model CommunityPartner {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  logo_url      String?
  website_url   String?
  display_order Int
  is_active     Boolean  @default(true)

  @@map("community_partners")
}

model Lead {
  id         String   @id @default(uuid()) @db.Uuid
  full_name  String
  city       String?
  phone      String?
  email      String
  source     String?
  status     String   @default("new")
  created_at DateTime @default(now())

  @@map("leads")
}

model SiteSetting {
  id             String   @id @default(uuid()) @db.Uuid
  address        String?
  contact_email  String?
  contact_phone  String?
  certifications String   @default("[]")
  updated_at     DateTime @updatedAt

  @@map("site_settings")
}

model User {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @unique
  password   String
  created_at DateTime @default(now())

  @@map("users")
}

model MentoredStartup {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  logo_url      String?
  website_url   String?
  display_order Int
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@map("mentored_startups")
}

model PitchDeck {
  id              String   @id @default(uuid()) @db.Uuid
  company         String
  tagline         String?
  sector          String?
  round           String?
  year            Int?
  raisedThisRound String?
  totalRaised     String?
  investors       String[]
  outcome         String?
  keyLesson       String?
  sourceUrl       String?
  deckUrl         String?
  tags            String[]
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  @@map("pitch_decks")
}

model Grant {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  amount      String?
  deadline    String?
  eligibility String?
  link        String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  @@map("grants")
}

model Investor {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  firm            String?
  type            String?
  stages          String[]
  sectors         String[]
  ticketSize      String?
  about           String?
  linkedin        String?
  logo_url        String?
  poc_name        String?
  poc_designation String?
  poc_linkedin    String?
  poc_photo       String?
  portfolio_cos   String[]
  portfolio_logos Json?
  twitter         String?
  org_linkedin    String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())

  @@map("investors")
}

model Incubator {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  location      String?
  focus         String[]
  programLength String?
  equityTaken   String?
  website       String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())

  @@map("incubators")
}

model FounderEvent {
  id               String   @id @default(uuid()) @db.Uuid
  tag              String?
  eventName        String
  exhibitionCentre String?
  location         String?
  startDate        String?
  month            String?
  weblink          String?
  priority         String?
  description      String?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  @@map("founder_events")
}

model ChatWidget {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  subtitle      String?
  icon          String?
  link          String
  is_active     Boolean  @default(true)
  display_order Int
  created_at    DateTime @default(now())

  @@map("chat_widgets")
}
